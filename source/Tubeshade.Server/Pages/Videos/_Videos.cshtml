@using System.Globalization
@using NodaTime.Text
@using Tubeshade.Server.Pages.Shared
@model Tubeshade.Server.Pages.Shared.PaginatedData<VideoModel>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr))">
    @foreach (var (index, video) in Model.Data.Index())
    {
        <div class="card m-1">
            <div class="position-relative" style="aspect-ratio: 16 / 9">
                <a asp-page="@(Model.LibraryId is not null ? "/Libraries/Videos/Video" : "/Videos/Video")"
                   asp-route-libraryId="@Model.LibraryId" asp-route-videoId="@video.Video.Id"
                   class="@(video.Video.Thumbnails is [] ? "tubeshade-missing-thumbnail" : string.Empty)">
                    @if (video.Video.Thumbnails is not [])
                    {
                        <img class="card-img-top tubeshade-video-thumbnail"
                             loading="lazy" decoding="async" fetchpriority="@(index < 7 ? "high" : "low")"
                             alt="@video.Video.Name" title="@video.Video.Name"
                             src="@video.GetThumbnailSource(Url)" srcset="@video.GetThumbnailSourceSet(Url)"
                             sizes="auto, (max-width: 557px) 510px, (max-width: 820px) 380px, (max-width: 1080px) 320px, 280px"/>
                    }
                    else
                    {
                        @video.Video.Name
                    }
                </a>
                @if (video is { DurationInSeconds: { } durationInSeconds, Video.Position: { } position } &&
                     Math.Abs(durationInSeconds - position) > Defaults.PlaybackEpsilon &&
                     position > Defaults.PlaybackEpsilon)
                {
                    <progress max="@durationInSeconds.ToString(CultureInfo.InvariantCulture)"
                              value="@position.ToString(CultureInfo.InvariantCulture)"
                              class="position-absolute w-100" style="transform: translate(0,-50%)">
                    </progress>
                }
            </div>

            <div class="card-body p-2">
                <h6 class="card-title text-truncate mb-0" title="@video.Video.Name">@video.Video.Name</h6>

                <div class="d-flex d-inline justify-content-between gap-3">
                    <a asp-page="@(Model.LibraryId is not null ? "/Libraries/Channels/Channel" : "/Channels/Channel")"
                       asp-route-libraryId="@Model.LibraryId" asp-route-channelId="@video.Video.ChannelId"
                       class="text-truncate">
                        @video.Channel.Name
                    </a>
                    <form>
                        <input value="@(video.Video.Id)" name="videoId" hidden/>
                        <div class="form-check form-switch">
                            <input id="viewed@(video.Video.Id.ToString("N"))" checked="@(video.Viewed)" name="viewed"
                                   type="checkbox" role="switch" switch title="Viewed" class="form-check-input"
                                   hx-post="" hx-page-handler="Viewed" hx-swap="none"/>
                            <label for="viewed@(video.Video.Id.ToString("N"))" class="form-check-label" hidden>
                                @SharedResources.Filters_ViewStatus_viewed
                            </label>
                        </div>
                    </form>
                </div>

                <div class="d-flex d-inline justify-content-between">
                    <time datetime="@InstantPattern.General.Format(video.Video.PublishedAt)">
                        @LocalDatePattern.Iso.Format(video.Video.PublishedAt.InUtc().Date)
                    </time>
                    <div>
                        @if (video is { ActualDuration: { } actualDuration, Video.Duration: { } duration })
                        {
                            <span>@(RoundedHumanReadablePeriodPattern.TwoPlaces.Format(duration))</span>
                            @if (duration != actualDuration)
                            {
                                <span>(@(RoundedHumanReadablePeriodPattern.TwoPlaces.Format(actualDuration)))</span>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
