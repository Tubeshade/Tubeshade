@using Tubeshade.Data.Media
@using Tubeshade.Data.Media.Channels
@using Tubeshade.Server.Pages.Shared
@model IChannelPage

<search>
    <form method="get" class="row row-cols-1 row-cols-sm-auto g-2 align-items-center mb-2"
          hx-get="" hx-page-handler="" hx-params="not __Invariant" hx-push-url="true"
          hx-trigger="input changed delay:100ms" hx-target="#channels">

        <div class="col-12 col-md">
            <label asp-for="Query" hidden="hidden">@SharedResources.Filters_Search</label>
            <input asp-for="Query" class="form-control" type="search" placeholder="@SharedResources.Filters_Search"/>
        </div>

        <div class="col-12">
            <label asp-for="Availability" hidden="hidden">@SharedResources.Filters_Availability</label>
            <select asp-for="Availability" class="form-select">
                <option value="">@SharedResources.Filters_Availability_Any</option>
                @foreach (var availability in ExternalAvailability.List)
                {
                    <option value="@availability.Name">@availability.LocalizedName</option>
                }
            </select>
        </div>

        <div class="col-12">
            <label asp-for="SortBy" hidden="hidden">@SharedResources.Filters_SortChannelBy</label>
            <select asp-for="SortBy" class="form-select">
                @foreach (var sortBy in SortChannelBy.List)
                {
                    <option value="@sortBy.Name">@sortBy.LocalizedName</option>
                }
            </select>
        </div>

        <div class="col-12">
            <label asp-for="SortDirection" hidden="hidden">@SharedResources.Filters_SortDirection</label>
            <select asp-for="SortDirection" class="form-select">
                @foreach (var direction in SortDirection.List)
                {
                    <option value="@direction.Name">@direction.LocalizedName</option>
                }
            </select>
        </div>

        <div class="col-12">
            <label asp-for="PageSize" hidden="hidden">@SharedResources.Filters_PageSize</label>
            <input asp-for="PageSize" class="form-control" type="number" placeholder="@SharedResources.Filters_PageSize"
                   value="@(Model.PageSize is null or Defaults.PageSize ? null : Model.PageSize)"/>
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary" title="@SharedResources.Filters_Search">
                <span class="visually-hidden">@SharedResources.Filters_Search</span>🔎︎
            </button>
        </div>

        <div class="col-auto">
            @if (Model.PageData.LibraryId is { } libraryId)
            {
                <a asp-page="/Libraries/Channels/Create" asp-route-libraryId="@libraryId"
                   class="btn btn-success" title="@SharedResources.Button_CreateChannel">
                    <span class="visually-hidden">@SharedResources.Button_CreateChannel</span>+
                </a>
            }
            else
            {
                <a asp-page="/Channels/Create"
                   class="btn btn-success" title="@SharedResources.Button_CreateChannel">
                    <span class="visually-hidden">@SharedResources.Button_CreateChannel</span>+
                </a>
            }
        </div>

        <input asp-for="PageIndex" value="@Model.PageIndex" hidden="hidden"/>
    </form>
</search>
