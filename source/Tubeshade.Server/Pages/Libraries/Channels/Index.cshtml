@page "~/Libraries/{libraryId:guid}/Channels/{handler?}"
@model Index
@{
    ViewData["Title"] = $"{SharedResources.Channels} - {Model.Library.Name}";
}

@section Navigation
{
    <partial name="Libraries/_LibraryNavigation" for="Library"/>
}

<partial name="Channels/_Channels" for="Channels"/>

<div class="row">
    <div class="col-12 col-sm-4 col-lg-3 col-xxl-2">
        <a asp-page="/Libraries/Channels/Create" asp-route-libraryId="@Model.LibraryId"
           class="btn btn-primary w-100" type="button">
            @SharedResources.Button_CreateChannel
        </a>
    </div>
</div>
